{
  "name": "@almadar/analytics",
  "version": "0.1.0",
  "description": "Cookieless, GDPR-friendly first-party analytics beacon for Docusaurus sites and SPA apps.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.js"
    },
    "./docusaurus": {
      "types": "./dist/docusaurus.d.ts",
      "import": "./dist/docusaurus.js",
      "require": "./dist/docusaurus.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest --run",
    "prepublishOnly": "pnpm run build",
    "prepare": "git config core.hooksPath .githooks"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@almadar/eslint-plugin": ">=2.7.0",
    "@types/react": "^18.2.0 || ^19.0.0",
    "@typescript-eslint/parser": "8.56.0",
    "eslint": "10.0.0",
    "react": "^18 || ^19",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/almadar-io/almadar-analytics.git"
  },
  "license": "BSL-1.1",
  "keywords": [
    "almadar",
    "analytics",
    "cookieless",
    "gdpr",
    "privacy",
    "docusaurus"
  ],
  "homepage": "https://github.com/almadar-io/almadar-analytics#readme"
}
